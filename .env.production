# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================

# Bot Configuration
BOT_TOKEN_ALPHA=your_production_bot_token_here
BOT_TOKEN_BETA=your_beta_bot_token_here
BOT_NAME_ALPHA=fam_tree_bot
BOT_NAME_BETA=famtreebbot

# Database Configuration
DATABASE_URL=postgresql+asyncpg://prod_user:secure_password@postgres:5432/famtreebot_prod
DB_HOST=postgres
DB_PORT=5432
DB_NAME=famtreebot_prod
DB_USER=prod_user
DB_PASSWORD=your_secure_production_password

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_WORKER_CONCURRENCY=8

# Webhook Configuration (Production)
WEBHOOK_ENABLED=true
WEBHOOK_HOST=https://api.famtreebot.com
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8443
WEBHOOK_SECRET=your_super_secret_webhook_key

# AI/ML Configuration
OPENAI_API_KEY=your_openai_api_key
HUGGINGFACE_API_KEY=your_hf_api_key
AI_ENABLED=true

# Blockchain Configuration
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_project_id
POLYGON_RPC_URL=https://polygon-rpc.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BLOCKCHAIN_ENABLED=true

# Security Configuration
SECRET_KEY=your_super_secret_production_key_32_chars
ENCRYPTION_KEY=your_encryption_key_32_chars
JWT_SECRET=your_jwt_secret_key

# Monitoring
SENTRY_DSN=https://...@sentry.io/...
PROMETHEUS_PORT=9090

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=WARNING
